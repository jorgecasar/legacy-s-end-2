{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"lib": ["ES2022", "DOM"],
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"moduleResolution": "bundler",
		"forceConsistentCasingInFileNames": true,
		"useDefineForClassFields": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": false,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["src/**/*.js", "docs/**/*.md"],
	"exclude": ["node_modules", "dist", ".rulesync", ".serena", ".agent", ".gemini"]
}
