{
  "name": "@legacys-end/ai-orchestration",
  "version": "1.0.0",
  "description": "Standalone AI Orchestration Pipeline for GitHub Actions",
  "author": "jorgecasar",
  "bin": {
    "ai-orchestration": "./src/index.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "npm run build",
    "build": "ncc build src/index.js -o dist --license licenses.txt",
    "test": "npm run test:ci && npm run test:integration",
    "test:ci": "NODE_ENV=test && GH_TOKEN=test node --test __tests__/*.spec.js",
    "test:integration": "NODE_ENV=test node --test __tests__/*.integration.spec.js",
    "test:coverage": "NODE_ENV=test c8 --reporter=text --reporter=html npm run test:ci"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/gemini-cli": "0.29.7",
    "js-yaml": "^4.1.1",
    "octokit": "^5.0.5",
    "openai": "^6.25.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "c8": "^11.0.0"
  }
}
