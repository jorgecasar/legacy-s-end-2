{
  "name": "@legacys-end/core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./domain/*.js": "./src/domain/*.js",
    "./domain/entities/*.js": "./src/domain/entities/*.js",
    "./domain/services/*.js": "./src/domain/services/*.js",
    "./use-cases/*.js": "./src/use-cases/*.js",
    "./use-cases/ports/*.js": "./src/use-cases/ports/*.js",
    "./infrastructure/*.js": "./src/infrastructure/*.js"
  },
  "scripts": {
    "test": "node --test __tests__/*.spec.js",
    "test:coverage": "node --test --experimental-test-coverage __tests__/*.spec.js",
    "check": "oxfmt check src",
    "format": "oxfmt format src"
  }
}
