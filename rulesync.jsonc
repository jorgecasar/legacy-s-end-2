{
	"$schema": "https://github.com/dyoshikawa/rulesync/releases/download/v8.15.0/config-schema.json",
	"targets": ["geminicli", "claudecode"],
	"features": [
		"rules",
		"ignore",
		"mcp",
		"commands",
		"subagents",
		"skills",
		"hooks",
		"permissions"
	],
	"outputRoots": ["."],
	"delete": true,
	"verbose": false,
	"silent": false,
	"global": false,
	"simulateCommands": false,
	"simulateSubagents": false,
	"simulateSkills": false,
	"mcpServers": {
		"serena": {
			"description": "Semantic code analysis and search (symbols, references, definitions)",
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"--context",
				"ide-assistant",
				"--enable-web-dashboard",
				"false",
				"--project",
				"."
			],
			"env": {}
		},
		"context7": {
			"description": "Up-to-date library documentation search (Lit, Web Awesome, @lit/localize, etc.)",
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@upstash/context7-mcp"],
			"env": {}
		},
		"playwright": {
			"description": "Browser automation via Playwright: navigate, click, type, snapshot, E2E test execution",
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@playwright/mcp@latest"],
			"env": {}
		},
		"chrome-devtools": {
			"description": "Chrome DevTools bridge: inspect DOM/CSS, execute JS, record performance traces on live browser",
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "chrome-devtools-mcp@latest"],
			"env": {}
		}
	},
	"sources": [
		{
			"source": ".",
			"commands": ["*"],
			"subagents": ["*"],
			"skills": ["*"]
		},
		{
			"source": "addyosmani/agent-skills",
			"commands": [
				"build",
				"code-simplify",
				"planning",
				"review",
				"ship",
				"spec",
				"test"
			],
			"subagents": [
				"code-reviewer",
				"security-auditor",
				"test-engineer"
			],
			"skills": [
				"api-and-interface-design",
				"browser-testing-with-devtools",
				"ci-cd-and-automation",
				"code-review-and-quality",
				"code-simplification",
				"context-engineering",
				"debugging-and-error-recovery",
				"deprecation-and-migration",
				"documentation-and-adrs",
				"frontend-ui-engineering",
				"git-workflow-and-versioning",
				"idea-refine",
				"incremental-implementation",
				"performance-optimization",
				"planning-and-task-breakdown",
				"security-and-hardening",
				"shipping-and-launch",
				"source-driven-development",
				"spec-driven-development",
				"test-driven-development",
				"using-agent-skills"
			]
		},
		{
			"source": "sickn33/antigravity-awesome-skills",
			"skills": [
				// 🎯 Fundamentos y Gestión
				"concise-planning",
				"lint-and-validate",
				"kaizen",
				"code-review-checklist",
				"commit",
				"create-pr",
				"changelog-automation",
				"documentation-templates",
				"git-pushing",

				// 🎨 Frontend & UI
				"frontend-design",
				"frontend-security-coder",
				"javascript-pro",

				// 🏗️ Arquitectura y Patrones
				"architecture-decision-records",
				"architecture-patterns",
				"domain-driven-design",
				"ddd-context-mapping",
				"ddd-strategic-design",
				"ddd-tactical-patterns",
				"senior-architect",

				// 🎮 Game Development
				"game-development/game-design",
				"algorithmic-art",

				// 🐞 Calidad y Testing
				"test-driven-development",
				"test-fixing",
				"e2e-testing-patterns",
				"browser-automation",
				"systematic-debugging",
				"verification-before-completion",
				"receiving-code-review",
				"requesting-code-review"
			]
		},
		{
			"source": "crystian/skills",
			"skills": [
				"skill-optimizer"
			]
		}
	]
}
