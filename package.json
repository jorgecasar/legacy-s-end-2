    "@legacys-end/ai-orchestration": "*",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "rulesync": "^7.6.3",
    "typescript": "^5.9.3"
  }
}
