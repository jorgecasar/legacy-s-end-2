{
  "name": "@legacys-end/root",
  "version": "1.0.0",
  "private": true,
  "description": "Legacy's End: A narrative game following Clean Architecture and modern standards.",
  "keywords": [],
  "license": "MIT",
  "author": "Jorge Casar",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "rulesync": "rulesync",
    "serena": "uvx --from git+https://github.com/oraios/serena serena",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:types": "tsc -p jsconfig.json",
    "test": "npm test --workspaces --if-present",
    "test:coverage": "npm test:coverage --workspaces --if-present",
    "format": "oxfmt --no-error-on-unmatched-pattern",
    "format:check": "oxfmt --check --no-error-on-unmatched-pattern",
    "check": "npm run format:check && npm run lint && npm run test",
    "check:fix": "npm run format && npm run lint:fix",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@awesome.me/webawesome": "^3.2.1",
    "@chromatic-com/storybook": "^5.0.1",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@legacys-end/ai-orchestration": "*",
    "@storybook/addon-a11y": "^10.2.13",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/addon-vitest": "^10.2.13",
    "@storybook/web-components-vite": "^10.2.13",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "playwright": "^1.58.2",
    "rulesync": "^7.10.0",
    "storybook": "^10.2.13",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
